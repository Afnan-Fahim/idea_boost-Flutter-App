    };

    // Three-tier lookup
    if (localeInstructions.containsKey(locale)) {
      // Tier 1: Exact locale match
      debugPrint('🌍 Priority 3 Locale [exact]: $locale');
      return localeInstructions[locale]!;
    } else if (localeInstructions.containsKey(langCode)) {
      // Tier 2: Base language fallback
      debugPrint('🌍 Priority 3 Locale [base-lang]: $locale → $langCode');
      return localeInstructions[langCode]!;
    } else {
      // Tier 3: Unknown locale — AI self-adaptation
      debugPrint('🌍 Priority 3 Locale [unmatched]: $locale');
      return '\n\n📍 LOCALE: "$locale"\n'
          'Detect and respond in the primary language of the "$locale" region. '
          'Adapt your tone and cultural communication norms to match the '
          '"$locale" region authentically. If the language cannot be determined, '
          'default to English.';
    }
  }

  String _addPriority4Enhancements(String prompt, PromptContext context) {
    // Add relevance guidance
    if (context.domain != null) {
      prompt += '\n\n💼 Domain: ${context.domain}';
    }

    if (context.audienceType != null) {
      prompt += '\n👥 Target Audience: ${context.audienceType}';
    }

    // Add conversation history context if present
    if (context.conversationHistory != null &&
        context.conversationHistory!.isNotEmpty) {
      prompt +=
          '\n📖 Conversation Context: ${context.conversationHistory!.length} previous exchanges';
    }

    return prompt;
  }

  String _addPriority5Enhancements(String prompt, PromptContext context) {
    // Add JSON formatting instructions
    if (context.enforceStrictJson && context.jsonStructure != null) {
      prompt += '\n\n📋 JSON Format Required:';
      prompt +=
          '\nReturn response as valid JSON with these fields: ${(context.jsonStructure!.keys.toList()).join(', ')}';
    }

    // Add constraints
    if (context.jsonConstraints != null) {
      prompt += '\n\n🔒 Constraints:';
      context.jsonConstraints!.forEach((key, value) {
        prompt += '\n  • $key: $value';
      });
    }

    return prompt;
  }
}
