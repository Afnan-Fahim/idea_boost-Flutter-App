/// lib/core/prompt_system/prompt_handler.dart
///
/// Central Prompt Handler - Smart, minimal approach to prompt orchestration.
/// Manages the priority-based assembly of prompts from ViewModels to backend.
///
/// ARCHITECTURE:
/// ViewModels → PromptRequest → PromptHandler → PromptContext → PromptBuilder → PromptResult → AiRepository

import 'package:flutter/foundation.dart';
import 'prompt_template.dart';
import 'models/prompt_request.dart';
import 'models/prompt_context.dart';
import 'models/prompt_result.dart';
import 'validators/json_validator.dart';

class PromptHandler {
  /// Singleton instance
  static final PromptHandler _instance = PromptHandler._internal();

  factory PromptHandler() {
    return _instance;
  }

  PromptHandler._internal();

  /// The JSON validator for Priority 5 (JSON formatting & constraints)
  final JsonValidator _jsonValidator = JsonValidator();

  /// Safe cast to String - handles Map, List, String, or other types
  String? _safeStringCast(dynamic value) {
    if (value is String) return value;
    if (value is Map) return value.toString();
    if (value is List) return value.join(', ');
    if (value == null) return null;
    return value.toString();
  }

  /// ============ MAIN FLOW ============
  ///
  /// Process a prompt request from ViewModel through the priority system.
  /// This is the main entry point for all generators.
  ///
  /// Flow:
  /// 1. Receive PromptRequest from ViewModel
  /// 2. Build PromptContext with all priorities applied
  /// 3. Use PromptBuilder to assemble final prompt
  /// 4. Validate against JSON constraints (Priority 5)
  /// 5. Return PromptResult ready for AiRepository

  Future<PromptResult> handlePromptRequest({
    required String language,
    required String userPrompt,
    required PromptRequest request,
    required String locale,
    String? generatorType,
  }) async {
    try {
      debugPrint(
        '╔════════════════════════════════════════════════════════════════╗',
      );
      debugPrint(
        '║ 🎯 PROMPT HANDLER: Processing Request                         ║',
      );
      debugPrint(
        '╚════════════════════════════════════════════════════════════════╝',
      );

      // ✅ Step 1: Build PromptContext with priorities
      final context = _buildPromptContext(
        language: language,
        userPrompt: userPrompt,
        request: request,
        locale: locale,
        generatorType: generatorType,
      );

      debugPrint(context.debugPriorities());

      // ✅ Step 2: Select appropriate template based on generator type
      final template = _selectTemplate(generatorType);
      debugPrint(
        '📍 PromptHandler: Selected template: ${template.templateName}',
      );

      // ✅ Step 3: Build final prompt using PromptBuilder
      final promptBuilder = PromptBuilder();
      final finalPrompt = promptBuilder.buildPrompt(context, template);

      debugPrint('''
╔════════════════════════════════════════════════════════════════╗
║                  📝 FINAL ASSEMBLED PROMPT                    ║
╠════════════════════════════════════════════════════════════════╣
$finalPrompt
╚════════════════════════════════════════════════════════════════╝
''');

      // ✅ Step 4: Validate against JSON constraints (Priority 5)
      final validationResult = _validatePrompt(
        finalPrompt,
        context.jsonConstraints,
      );

      // ✅ Step 5: Create and return PromptResult
      final result = PromptResult(
        finalPrompt: finalPrompt,
        appliedContext: _contextToMap(context),
        isValid: validationResult['isValid'] as bool,
        validationErrors: List<String>.from(validationResult['errors'] as List),
        executionInstructions: _generateExecutionInstructions(
          context,
          generatorType,
        ),
      );

      debugPrint(result.toString());

      return result;
    } catch (e, stack) {
      debugPrint('❌ PromptHandler ERROR: $e');
      debugPrint('Stack: $stack');
      return PromptResult(
        finalPrompt: userPrompt,
        appliedContext: {'error': e.toString()},
        isValid: false,
        validationErrors: [e.toString()],
      );
    }
  }

  /// ============ STEP 1: Build PromptContext with ALL PRIORITIES ============

  PromptContext _buildPromptContext({
    required String language,
    required String userPrompt,
    required PromptRequest request,
    required String locale,
    String? generatorType,
  }) {
    // Detect RTL languages
    final isRtl = _isRtlLanguage(language);

    // Determine cultural context from locale
    final culturalContext = _determineCulturalContext(locale, language);

    // Build the context with all priorities applied
    return PromptContext(
      // [1️⃣  PRIORITY 1: LANGUAGE - FOUNDATION]
      language: language,

      // [2️⃣  PRIORITY 2: PLATFORM, TONE, USER INPUT, JSON STRUCTURE]
      platform: request.platform,
      tone: request.tone,
      userPrompt: userPrompt,
      parameters: request.parameters,
      jsonStructure: request.jsonStructure,

      // [3️⃣  PRIORITY 3: LOCALE BEHAVIOR]
      locale: locale,
      isRtl: isRtl,
      culturalContext: culturalContext,

      // [4️⃣  PRIORITY 4: RELEVANCE]
      conversationHistory: request.conversationHistory,
      domain: _extractDomain(generatorType),
      audienceType: _safeStringCast(request.parameters?['audienceType']),

      // [5️⃣  PRIORITY 5: JSON FORMATTING & CONSTRAINTS]
      jsonConstraints: request.jsonStructure,
      enforceStrictJson: request.jsonStructure != null,

      // Backend fields
      rewardGrantToken: request.rewardGrantToken,
      quality: request.quality ?? 'nano',
    );
  }

  /// ============ STEP 2: Select Template Based on Generator Type ============

  PromptTemplate _selectTemplate(String? generatorType) {
    switch (generatorType?.toLowerCase()) {
      case 'script':
        return ScriptGeneratorTemplate();
      case 'comment':
        return CommentGeneratorTemplate();
      case 'hashtag':
        return HashtagGeneratorTemplate();
      case 'viral_rewrite':
        return ViralRewriteTemplate();
      case 'shot_ideas':
        return ShotIdeasTemplate();
      case 'refinement':
        return RefinementTemplate();
      default:
        return DefaultPromptTemplate();
    }
  }

  /// ============ STEP 3: Validate Prompt Against JSON Constraints ============

  Map<String, dynamic> _validatePrompt(
    String prompt,
    Map<String, dynamic>? constraints,
  ) {
    final errors = <String>[];
    bool isValid = true;

    if (constraints == null || constraints.isEmpty) {
      return {'isValid': true, 'errors': errors};
    }

    // Validate against constraints
    isValid = _jsonValidator.validatePrompt(prompt, constraints, errors);

    return {'isValid': isValid, 'errors': errors};
  }

  /// ============ HELPER METHODS ============

  bool _isRtlLanguage(String language) {
    // Common RTL languages: Arabic, Hebrew, Farsi, Urdu
    return ['ar', 'he', 'fa', 'ur'].contains(language.toLowerCase());
  }

  /// PATTERN FROM BACKEND (executed in executeAi.js):
  /// ═══════════════════════════════════════════════════════════════════════
  ///
  /// The LANGUAGE parameter is the authoritative source for:
  ///   • What language to generate content in
  ///   • What language-specific tone/voice to use
  ///   • Examples: "en", "ru", "hi", "ar", etc.
  ///
  /// The LOCALE parameter is the full OS locale and is used for:
  ///   • Regional/cultural tone adaptation
  ///   • Respecting cultural context (e.g., "en-PK" = English from Pakistan)
  ///   • Examples: "en-US", "en-PK", "ru-RU", "ar-SA", etc.
  ///
  /// KEY INSIGHT: These can differ!
  ///   Device locale: en-PK  (English from Pakistan)
  ///   App language:  ru      (User switched app to Russian)
  ///   → Generate in Russian, but respect Pakistan's cultural norms
  ///
  /// Cultural context = the full OS locale string (e.g., "en-PK", "ru-RU")
  /// This is NOT mixing language + region, it's just the device's locale setting.
  String _determineCulturalContext(String locale, String language) {
    // Return the full locale as-is - it IS the cultural context
    // Example: "en-PK" (device is set to English from Pakistan)
    // The language param (e.g., "ru") determines WHAT language to generate in
    // The locale param (e.g., "en-PK") determines CULTURAL TONE for that language
    return locale;
  }

  String _extractDomain(String? generatorType) {
    switch (generatorType?.toLowerCase()) {
      case 'script':
        return 'video_content';
      case 'comment':
        return 'social_engagement';
      case 'hashtag':
        return 'social_discovery';
      case 'viral_rewrite':
        return 'content_optimization';
      case 'shot_ideas':
        return 'creative_ideation';
      case 'refinement':
        return 'idea_enhancement';
      default:
        return 'general_content';
    }
  }

  Map<String, dynamic> _contextToMap(PromptContext context) {
    return {
      'language': context.language,
      'platform': context.platform,
      'tone': context.tone,
      'locale': context.locale,
      'isRtl': context.isRtl,
      'culturalContext': context.culturalContext,
      'domain': context.domain,
      'quality': context.quality,
    };
  }

  String _generateExecutionInstructions(
    PromptContext context,
    String? generatorType,
  ) {
    final instructions = <String>[];

    // Language instruction (Priority 1)
    instructions.add('Generate response in ${context.language}.');

    // Platform instruction (Priority 2)
    if (context.platform != null) {
      instructions.add('Optimize for ${context.platform} platform.');
    }

    // Tone instruction (Priority 2)
    if (context.tone != null) {
      instructions.add('Use a ${context.tone} tone.');
    }

    // RTL instruction (Priority 3)
    if (context.isRtl) {
      instructions.add('Format for RTL (right-to-left) language display.');
    }

    // Audience instruction (Priority 4)
    if (context.audienceType != null) {
      instructions.add('Target audience: ${context.audienceType}.');
    }

    // JSON instruction (Priority 5)
    if (context.enforceStrictJson && context.jsonStructure != null) {
      instructions.add(
        'Return valid JSON with fields: ${(context.jsonStructure!.keys.toList()).join(", ")}',
      );
    }

    return instructions.join('\n');
  }

  /// Debug method to show execution flow
  void debugShowFlow(String generatorType, PromptRequest request) {
    print('''
╔════════════════════════════════════════════════════════════════╗
║                 📊 PROMPT HANDLER FLOW                         ║
╠════════════════════════════════════════════════════════════════╣
║ Generator Type: $generatorType
║ Platform: ${request.platform ?? "—"}
║ Tone: ${request.tone ?? "—"}
║ Quality: ${request.quality ?? "nano"}
║ Has Reward Token: ${request.rewardGrantToken != null}
║ Has JSON Structure: ${request.jsonStructure != null}
║ Has Parameters: ${request.parameters != null}
╚════════════════════════════════════════════════════════════════╝
''');
  }
}

/// ============ PROMPT BUILDER ============
///
/// Constructs the final prompt string using the PromptContext and Template.

class PromptBuilder {
  String buildPrompt(PromptContext context, PromptTemplate template) {
    debugPrint(
      '📝 PromptBuilder: Assembling prompt with ${template.runtimeType}',
    );

    // Use template to build base prompt
    String prompt = template.buildBasePrompt(context);

    // Add priority 2 enhancements (platform, tone, parameters)
    prompt = _addPriority2Enhancements(prompt, context);

    // Add priority 3 enhancements (locale/cultural)
    prompt = _addPriority3Enhancements(prompt, context);

    // Add priority 4 enhancements (relevance)
    prompt = _addPriority4Enhancements(prompt, context);

    // Add priority 5 enhancements (JSON constraints)
    prompt = _addPriority5Enhancements(prompt, context);

    debugPrint('✅ PromptBuilder: Final prompt built (${prompt.length} chars)');

    return prompt;
  }

  String _addPriority2Enhancements(String prompt, PromptContext context) {
    // Add platform-specific instructions
    if (context.platform != null) {
      prompt +=
          '\n\n📱 Platform: Optimize specifically for ${context.platform}.';
    }

    // Add tone guidance
    if (context.tone != null) {
      prompt += '\n🎭 Tone: Use a ${context.tone} tone throughout.';
    }

    // Add parameters as additional guidance
    if (context.parameters != null && context.parameters!.isNotEmpty) {
      prompt += '\n\n⚙️ Additional Parameters:';
      context.parameters!.forEach((key, value) {
        prompt += '\n  • $key: $value';
      });
    }

    return prompt;
  }

  String _addPriority3Enhancements(String prompt, PromptContext context) {
    // [3️⃣ PRIORITY 3: LOCALE BEHAVIOR — Cultural & Tonal Adaptation]
    // These instructions were previously applied in the backend (executeAi.js).
    // They now live here in Priority 3 so the assembled prompt is self-contained.
    final locale = context.locale;
    final language = context.language;

    if (locale != null) {
      final instruction = _getCulturalInstruction(locale, language);
      if (instruction.isNotEmpty) {
        prompt += instruction;
      }
    }

    // Add RTL guidance if needed
    if (context.isRtl) {
      prompt +=
          '\n⚠️ RTL Language: Use appropriate RTL formatting and conventions.';
    }

    return prompt;
  }

  /// Returns the cultural/tonal instruction string for a given locale + language.
  /// Three-tier lookup (mirrors the removed backend logic from executeAi.js):
  ///   Tier 1 — Exact locale match : "en-PK", "ar-SA", "es-MX" …
  ///   Tier 2 — Base language match: "fr-BE" → "fr", "de-LU" → "de" …
  ///   Tier 3 — Fully unknown      : AI self-adaptation fallback
  String _getCulturalInstruction(String locale, String language) {
    // Derive the base language code from locale (e.g. "en-PK" → "en")
    final langCode = language.isNotEmpty
        ? language
        : locale.split('-').first.toLowerCase();

    // ─────────────────────────────────────────────────────────────────────────
    // LOCALE INSTRUCTIONS MAP — exact same strings as removed from executeAi.js
    // ─────────────────────────────────────────────────────────────────────────
    final localeInstructions = <String, String>{
      // ══════════ ENGLISH & REGIONAL VARIANTS ══════════
      'en': '\nLANGUAGE: English — Respond EXCLUSIVELY in English.\n'
          'TONE: Confident, clear, and conversational — like a knowledgeable friend, '
          'not a corporate manual. Be direct and purposeful. Use active voice. '
          'Avoid filler phrases, over-hedging, or unnecessary softening.',

      'en-US': '\nLANGUAGE: English (United States) — Respond EXCLUSIVELY in English.\n'
          'TONE: Confident, direct, and results-oriented. Conversational without being '
          'casual. Get to the point fast — Americans value efficiency and clarity. '
          'Active voice throughout. Avoid corporate jargon and hollow filler phrases.',

      'en-GB': '\nLANGUAGE: English (United Kingdom) — Respond EXCLUSIVELY in English.\n'
          'TONE: Precise, articulate, and measured. Understated rather than enthusiastic. '
          'Use British spelling (colour, organise, whilst). Intellectually rigorous. '
          'Dry wit is acceptable. Never over-sell — let the substance speak.',

      'en-AU': '\nLANGUAGE: English (Australia) — Respond EXCLUSIVELY in English.\n'
          'TONE: Direct, practical, and unpretentious. Friendly without being over-eager. '
          'Straightforward and no-nonsense. Australians distrust hype — be grounded, '
          'clear, and genuine. Conversational but professional.',

      'en-IN': '\nLANGUAGE: English (India) — Respond EXCLUSIVELY in English.\n'
          'TONE: Warm, respectful, and contextually aware. Balance professionalism with '
          'approachability. Acknowledge hierarchy and social context naturally. '
          'Be clear, thorough, and educational. Avoid excessive casualness.',

      'en-PK': '\nLANGUAGE: English (Pakistan) — Respond EXCLUSIVELY in English.\n'
          'TONE: Formal, respectful, and dignified. \'Sir/Ma\'am\' register is appropriate. '
          'Hierarchy and seniority are respected — never be dismissive of authority. '
          'Professional and structured. Warmth through courtesy, not casualness. '
          'Avoid Western informality; maintain Pakistani professional etiquette.',

      'en-NG': '\nLANGUAGE: English (Nigeria) — Respond EXCLUSIVELY in English.\n'
          'TONE: Dynamic, confident, and respectful. Professional yet vibrant. '
          'Nigerians are direct and entrepreneurial — be substantive and ambitious. '
          'Respectful of elders and titles. Energetic without being frivolous.',

      'en-ZA': '\nLANGUAGE: English (South Africa) — Respond EXCLUSIVELY in English.\n'
